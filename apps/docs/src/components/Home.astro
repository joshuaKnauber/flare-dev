---
const skillSnippet = `npx skills add joshuaKnauber/flare-dev`;

const viteSnippet = `<span class="dim">// vite.config.ts</span>
<span class="kw">import</span> flare <span class="kw">from</span> <span class="str">"flare-dev/vite"</span>

<span class="kw">export default</span> defineConfig({
  plugins: [flare()],
})`;

const scriptSnippet = `&lt;script src=<span class="str">"https://unpkg.com/flare-dev/dist/flare.js"</span>&gt;&lt;/script&gt;`;

const bridgeSnippet = `npx flare-dev bridge`;
---

<div class="page">
  <main>
    <div class="icon-wrap">
      <svg viewBox="100 95 315 325" width="18" height="18" fill="none">
        <path d="M268.585 309.261C268.585 320.923 265.129 332.322 258.655 342.018C252.181 351.714 242.979 359.271 232.213 363.733C221.447 368.196 209.6 369.363 198.171 367.088C186.742 364.813 176.243 359.198 168.003 350.952C159.763 342.707 154.152 332.201 151.878 320.764C149.605 309.327 150.772 297.472 155.231 286.699C159.691 275.925 167.242 266.717 176.932 260.238C186.621 253.76 198.012 250.302 209.665 250.302C225.292 250.302 240.278 256.514 251.328 267.571C262.377 278.628 268.585 293.624 268.585 309.261Z" fill="white"/>
