---
const skillSnippet = `npx skills add joshuaKnauber/flare-dev`;

const viteSnippet = `<span class="dim">// vite.config.ts</span>
<span class="kw">import</span> flare <span class="kw">from</span> <span class="str">"flare-dev/vite"</span>

<span class="kw">export default</span> defineConfig({
  plugins: [flare()],
})`;

const scriptSnippet = `&lt;script src=<span class="str">"https://unpkg.com/flare-dev/dist/flare.js"</span>&gt;&lt;/script&gt;`;

const bridgeSnippet = `npx flare-dev bridge`;
---

<div class="page">
  <main>
    <div class="gh-button-wrap">
      <a class="github-button" href="https://github.com/joshuaKnauber/flare-dev" data-color-scheme="no-preference: light; light: light; dark: light;" data-icon="octicon-star" data-size="large" data-show-count="true" aria-label="Star joshuaKnauber/flare-dev on GitHub">Star</a>
    </div>
    <h1 class="text-pretty">Design in the browser with Flare.</h1>
    <p class="sub">A visual CSS editor for designers who ship with AI.</p>

    <div class="video-wrap">
      <video src="/demo.mp4" autoplay loop muted playsinline></video>
    </div>

    <button class="cta plausible-event-name=Try+It" id="try-btn">Try it here</button>
    <p class="mobile-hint">Best experienced on desktop</p>

    <section class="get-started" id="bridge-onboarding">
      <div class="gs-card">
        <div class="gs-row" data-copy="skill">
          <span class="gs-num">1</span>
          <div class="gs-text">
            <span class="gs-label">Install the skill in your terminal</span>
            <pre set:html={skillSnippet} />
          </div>
          <button class="gs-copy plausible-event-name=Copy" aria-label="Copy">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          </button>
        </div>
        <div class="gs-divider"></div>
        <div class="gs-row" data-copy="run">
          <span class="gs-num">2</span>
          <div class="gs-text">
            <span class="gs-label">Run in Claude Code, Cursor, or any agent</span>
            <pre>/flare-dev</pre>
          </div>
          <button class="gs-copy plausible-event-name=Copy" aria-label="Copy">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          </button>
        </div>
      </div>
      <p class="gs-compat">Works with Claude Code, Cursor, Windsurf, and any AI agent.</p>
      <button class="gs-alt-toggle" id="alt-toggle">Manual setup &darr;</button>
      <div class="alt-panels" id="alt-panels">
        <p class="alt-note">The skill (step 1 above) is still needed for agent instructions.</p>
        <div class="alt-tabs" role="tablist">
          <button class="cb-tab active plausible-event-name=Vite+Plugin" data-tab="vite" role="tab" aria-selected="true">Vite Plugin</button>
          <button class="cb-tab plausible-event-name=Script+Tag" data-tab="script" role="tab" aria-selected="false">Script Tag</button>
        </div>
        <div class="cb-body">
          <div class="panel active" id="panel-vite">
            <div class="step-label">Add the plugin</div>
            <div class="snippet" data-copy="vite">
              <button class="snippet-copy plausible-event-name=Copy" aria-label="Copy">Copy</button>
              <pre set:html={viteSnippet} />
            </div>
            <div class="snippet-divider"></div>
            <div class="step-label">Start the bridge</div>
            <div class="snippet" data-copy="bridge">
              <button class="snippet-copy plausible-event-name=Copy" aria-label="Copy">Copy</button>
              <pre set:html={bridgeSnippet} />
            </div>
          </div>
          <div class="panel" id="panel-script">
            <div class="step-label">Add a script tag</div>
            <div class="snippet" data-copy="script">
              <button class="snippet-copy plausible-event-name=Copy" aria-label="Copy">Copy</button>
              <pre set:html={scriptSnippet} />
            </div>
            <div class="snippet-divider"></div>
            <div class="step-label">Start the bridge</div>
            <div class="snippet" data-copy="bridge">
              <button class="snippet-copy plausible-event-name=Copy" aria-label="Copy">Copy</button>
              <pre set:html={bridgeSnippet} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="links">
      <a href="https://github.com/joshuaKnauber/flare-dev" class="social plausible-event-name=Github" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <a href="https://x.com/joshuaKnauber" class="social plausible-event-name=X" target="_blank" rel="noopener" aria-label="X">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
    </div>
  </main>
</div>

<style>
  /* ── Base ─────────────────────────────── */
  .page {
    min-height: 100vh;
    background: #ffffff;
    font-family: 'Inter', sans-serif;
    color: #111;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ── Video ────────────────────────────── */
  .video-wrap {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    margin-top: 40px;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .video-wrap video {
    width: 100%;
    display: block;
  }

  /* ── Hero ─────────────────────────────── */
  main {
    max-width: 620px;
    margin: 0 auto;
    padding: 100px 24px 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .gh-button-wrap {
    margin-bottom: 24px;
    height: 28px;
  }

  h1 {
    font-size: 46px;
    font-weight: 580;
    letter-spacing: -0.035em;
    line-height: 1.08;
    text-align: center;
    margin: 0;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) 0.04s both;
  }

  .sub {
    font-size: 17px;
    color: #6b6b6b;
    text-align: center;
    margin: 14px 0 0;
    line-height: 1.5;
    letter-spacing: -0.005em;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) 0.08s both;
  }

  .cta {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    padding: 10px 28px;
    border: none;
    border-radius: 10px;
    background: #ff7a00;
    color: #fff;
    cursor: pointer;
    margin-top: 32px;
    transition: background 0.15s, transform 0.15s;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) 0.12s both;
  }

  .cta:hover {
    background: #e86e00;
  }

  .cta:active {
    transform: scale(0.97);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Get Started ────────────────────── */
  .get-started {
    width: 100%;
    margin-top: 48px;
    animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.16s both;
  }

  .gs-card {
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    overflow: hidden;
  }

  .gs-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
  }

  .gs-divider {
    height: 1px;
    background: #e8e8e8;
  }

  .gs-num {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: #ff7a00;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid #ffd9b3;
    border-radius: 6px;
    background: #fff7ee;
    flex-shrink: 0;
  }

  .gs-text {
    flex: 1;
    min-width: 0;
  }

  .gs-label {
    display: block;
    font-size: 12px;
    color: #999;
    margin-bottom: 4px;
    letter-spacing: -0.005em;
  }

  .gs-row pre {
    margin: 0;
    font-family: 'Geist Mono', monospace;
    font-size: 13.5px;
    color: #333;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .gs-copy {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    background: #fafafa;
    color: #bbb;
    cursor: pointer;
    transition: all 0.15s;
  }

  .gs-copy:hover {
    border-color: #ccc;
    color: #666;
    background: #f0f0f0;
  }

  .gs-copy.copied {
    color: #ff7a00;
    border-color: #ffd9b3;
    background: #fff7ee;
  }

  .gs-compat {
    font-size: 12.5px;
    color: #bbb;
    text-align: center;
    margin: 20px 0 0;
    letter-spacing: -0.005em;
  }

  .gs-alt-toggle {
    font-family: 'Inter', sans-serif;
    font-size: 12.5px;
    font-weight: 500;
    color: #ccc;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    margin: 12px auto 0;
    display: block;
    transition: color 0.15s;
    letter-spacing: -0.005em;
  }

  .gs-alt-toggle:hover {
    color: #999;
  }

  .alt-note {
    font-size: 12.5px;
    color: #aaa;
    margin: 0;
    padding: 12px 16px 0;
  }

  .alt-panels {
    display: none;
    margin-top: 16px;
    border: 1px solid #e5e5e5;
    border-radius: 12px;
    overflow: hidden;
  }

  .alt-panels.open {
    display: block;
    animation: panelIn 0.15s ease;
  }

  .alt-tabs {
    display: flex;
    padding: 0 4px;
    background: #fff;
    border-bottom: 1px solid #eee;
  }

  .cb-tab {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    padding: 12px 14px;
    border: none;
    background: none;
    color: #bbb;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s;
    letter-spacing: -0.005em;
  }

  .cb-tab.active {
    color: #111;
    border-bottom-color: #ff7a00;
  }

  .cb-tab:not(.active):hover {
    color: #888;
  }

  .snippet {
    position: relative;
  }

  .snippet-copy {
    position: absolute;
    top: -10px;
    right: -10px;
    font-family: 'Geist Mono', monospace;
    font-size: 11.5px;
    font-weight: 500;
    padding: 4px 10px;
    border: 1px solid #e8e8e8;
    background: #f0f0f0;
    color: #999;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.01em;
  }

  .snippet-copy:hover {
    border-color: #ccc;
    color: #555;
    background: #eaeaea;
  }

  .snippet-copy.copied {
    color: #ff7a00;
    border-color: #ffd9b3;
  }

  .snippet-divider {
    border-top: 1px solid #e5e5e5;
    margin: 14px -22px 20px;
  }

  .step-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 8px;
  }

  .cb-body {
    padding: 20px 22px;
    background: #f8f8f8;
  }

  .panel {
    display: none;
  }

  .panel.active {
    display: block;
    animation: panelIn 0.15s ease;
  }

  @keyframes panelIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .cb-body pre {
    margin: 0;
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
    line-height: 1.7;
    color: #444;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  /* Syntax colors */
  .cb-body :global(.kw) { color: #7c5ac2; }
  .cb-body :global(.str) { color: #c56e00; }
  .cb-body :global(.dim) { color: #b0b0b0; }

  /* ── Social Links ─────────────────────── */
  .links {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 40px;
    animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.32s both;
  }

  .social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    color: #bbb;
    transition: color 0.15s, background 0.15s;
  }

  .social:hover {
    color: #555;
    background: #f3f3f3;
  }

  .mobile-hint {
    display: none;
    font-size: 12.5px;
    color: #aaa;
    margin: 10px 0 0;
    letter-spacing: -0.005em;
  }

  /* ── Responsive ──────────────────────── */
  @media (max-width: 640px) {
    .mobile-hint {
      display: block;
    }
    main {
      padding: 64px 20px 56px;
    }

    h1 {
      font-size: 34px;
    }

    .sub {
      font-size: 15.5px;
    }

    .codeblock {
      margin-top: 40px;
    }

    .cb-body {
      padding: 16px 18px;
    }

    .snippet-divider {
      margin: 14px -18px;
    }

    .cb-body pre {
      font-size: 12px;
    }

  }
</style>

<script>
  // Tab switching
  const tabs = document.querySelectorAll<HTMLButtonElement>('.cb-tab');
  const panels = document.querySelectorAll<HTMLElement>('.panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      panels.forEach(p => p.classList.remove('active'));
      document.getElementById(`panel-${target}`)?.classList.add('active');
    });
  });

  // Toggle alternative methods
  document.getElementById('alt-toggle')?.addEventListener('click', () => {
    document.getElementById('alt-panels')?.classList.toggle('open');
  });

  // Copy texts
  const copyTexts: Record<string, string> = {
    skill: `npx skills add joshuaKnauber/flare-dev`,
    run: `/flare-dev`,
    vite: `// vite.config.ts\nimport flare from "flare-dev/vite"\n\nexport default defineConfig({\n  plugins: [flare()],\n})`,
    script: `<script src="https://unpkg.com/flare-dev/dist/flare.js"><\/script>`,
    bridge: `npx flare-dev bridge`,
  };

  // Try button
  document.getElementById('try-btn')?.addEventListener('click', () => {
    try {
      const val = String(Date.now());
      localStorage.setItem('flare-open', val);
      window.dispatchEvent(new StorageEvent('storage', { key: 'flare-open', newValue: val }));
    } catch {}
  });

  // Copy buttons (both .snippet-copy and .gs-copy)
  document.querySelectorAll<HTMLButtonElement>('.snippet-copy, .gs-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const container = btn.closest('[data-copy]');
      const key = container?.getAttribute('data-copy');
      if (!key || !copyTexts[key]) return;
      navigator.clipboard.writeText(copyTexts[key]);
      btn.classList.add('copied');
      setTimeout(() => { btn.classList.remove('copied'); }, 1800);
    });
  });
</script>
